# ============================================================
# PRODUCTION ENVIRONMENT — copy this to .env and fill values
# ============================================================

# Database (InfinityFree gives these when you create a DB)
DB_HOST=sql200.infinityfree.com
DB_NAME=if0_xxxxxxxx_tms
DB_USER=if0_xxxxxxxx
DB_PASS=your_db_password

# JWT — generate a long random string, e.g.:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-this-to-a-long-random-secret

# Frontend URL (your Vercel/Netlify URL — no trailing slash)
FRONTEND_URL=https://your-app.vercel.app

# App
APP_ENV=production
APP_DEBUG=false
APP_URL=https://yourdomain.infinityfree.net/backend
